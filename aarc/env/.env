VITE_GuideResetPassword =  "请联系管理员重置"

#可选广告水印内容
VITE_AdsTextLess = "http://aarc.jowei19.com"
VITE_AdsTextMore = "http://aarc.jowei19.com 开源免费的线路图编辑器"

#寻求帮助联系方式
VITE_GuideFindHelp = ""
VITE_GuideExtra = ""
#转正联系方式
VITE_GuideMemberApply = ""

VITE_FooterLinkLeft = "<a href='https://gitee.com'>友情链接(左)</a>"
VITE_FooterLinkRight = "<a href='https://gitee.com'>友情链接(右)</a>"

# turnstile 人机验证服务的网页端key，请自行申请（可选）
# 如果要使用，需与后端appsettings.json成对配置
# 注意：https网站才能正常使用，http下成功率较低
VITE_TurnstileSiteKey = ""

VITE_RailChess = "https://railchess.jowei19.com"
# OIDC 登录配置
# 填写主应用域名作为 Authority 即启用 OIDC 登录，例如 https://master.app
VITE_OidcAuthority=
# 为 truthy 时隐藏本地登录控件和注册按钮，仅保留 OIDC 登录
VITE_HideLocalAuth=false
